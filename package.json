{
  "name": "level-editor-2d",
  "version": "3.60.5",
  "description": "Профессиональный 2D редактор уровней с утилитарной архитектурой мирового класса",
  "main": "index.html",
  "type": "module",
  "scripts": {
    "start": "python -m http.server 8000",
    "start:node": "npx serve .",
    "dev": "python -m http.server 8000",
    "build:css": "tailwindcss -i styles/tailwind.css -o styles/tailwind.build.css --minify",
    "watch:css": "tailwindcss -i styles/tailwind.css -o styles/tailwind.build.css --watch",
    "validate:version": "node scripts/validate-version.js",
    "bump:patch": "node scripts/bump-version.mjs patch",
    "bump:minor": "node scripts/bump-version.mjs minor",
    "bump:major": "node scripts/bump-version.mjs major",
    "test": "vitest run",
    "lint": "eslint src",
    "check:size": "node scripts/check-file-size.js",
    "check": "npm run lint && npm run check:size && npm test && npx madge --circular src",
    "check:unused": "knip"
  },
  "keywords": [
    "level-editor",
    "2d",
    "game-development",
    "javascript",
    "es6-modules",
    "utility-architecture",
    "clean-code",
    "dry-principles"
  ],
  "author": "Level Editor Team",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "."
  },
  "homepage": "./index.html",
  "directories": {
    "doc": "./docs",
    "lib": "./src"
  },
  "files": [
    "src/",
    "docs/",
    "index.html",
    "start_Editor.bat",
    "start_Editor.vbs"
  ],
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.5",
    "eslint-plugin-import": "^2.32.0",
    "knip": "^6.26.0",
    "madge": "^8.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.13",
    "vitest": "^4.1.10"
  }
}
