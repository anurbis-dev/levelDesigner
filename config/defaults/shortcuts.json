{
  "editor": {
    "escape": {
      "key": "Escape",
      "description": "Cancel current actions"
    },
    "delete": {
      "key": "Delete",
      "description": "Delete selected objects"
    },
    "deleteAlt": {
      "key": "X",
      "description": "Delete selected objects (alternative)"
    },
    "duplicate": {
      "key": "D",
      "shiftKey": true,
      "description": "Duplicate selected objects"
    },
    "copy": {
      "key": "C",
      "ctrlKey": true,
      "description": "Copy selected objects to clipboard"
    },
    "cut": {
      "key": "X",
      "ctrlKey": true,
      "description": "Cut selected objects to clipboard"
    },
    "paste": {
      "key": "V",
      "ctrlKey": true,
      "description": "Paste objects from clipboard"
    },
    "focusSelection": {
      "key": "F",
      "description": "Focus on selected objects"
    },
    "focusAll": {
      "key": "A",
      "description": "Focus on all objects"
    },
    "toggleGrid": {
      "key": "G",
      "description": "Toggle grid visibility"
    },
    "groupObjects": {
      "key": "G",
      "shiftKey": true,
      "description": "Group selected objects"
    },
    "ungroupObjects": {
      "key": "G",
      "altKey": true,
      "description": "Ungroup selected objects"
    },
    "toggleParallax": {
      "key": "P",
      "description": "Toggle parallax"
    },
    "undo": {
      "key": "Z",
      "ctrlKey": true,
      "description": "Undo last action"
    },
    "redo": {
      "key": "Z",
      "ctrlKey": true,
      "shiftKey": true,
      "description": "Redo last undone action"
    },
    "redoAlt": {
      "key": "Y",
      "ctrlKey": true,
      "description": "Redo last undone action (alternative)"
    },
    "newLevel": {
      "key": "N",
      "ctrlKey": true,
      "altKey": true,
      "description": "Create new level (Ctrl+N alone is intercepted by the browser as \"new window\", so Alt is required)"
    },
    "openLevel": {
      "key": "O",
      "ctrlKey": true,
      "description": "Open level"
    },
    "saveLevel": {
      "key": "S",
      "ctrlKey": true,
      "description": "Save level"
    },
    "saveLevelAs": {
      "key": "S",
      "ctrlKey": true,
      "shiftKey": true,
      "description": "Save level as"
    },
    "nextLevel": {
      "key": "PageDown",
      "ctrlKey": true,
      "description": "Switch to next level tab"
    },
    "previousLevel": {
      "key": "PageUp",
      "ctrlKey": true,
      "description": "Switch to previous level tab"
    },
    "moveLayerUp": {
      "key": "PageUp",
      "description": "Move selected objects to upper layer"
    },
    "moveLayerUpExtreme": {
      "key": "PageUp",
      "shiftKey": true,
      "description": "Move selected objects to top layer"
    },
    "moveLayerDown": {
      "key": "PageDown",
      "description": "Move selected objects to lower layer"
    },
    "moveLayerDownExtreme": {
      "key": "PageDown",
      "shiftKey": true,
      "description": "Move selected objects to bottom layer"
    },
    "bringForward": {
      "key": "ArrowUp",
      "ctrlKey": true,
      "description": "Bring selected objects forward one step in stacking order"
    },
    "sendBackward": {
      "key": "ArrowDown",
      "ctrlKey": true,
      "description": "Send selected objects backward one step in stacking order"
    },
    "bringToFront": {
      "key": "ArrowUp",
      "ctrlKey": true,
      "shiftKey": true,
      "description": "Bring selected objects to front of stacking order"
    },
    "sendToBack": {
      "key": "ArrowDown",
      "ctrlKey": true,
      "shiftKey": true,
      "description": "Send selected objects to back of stacking order"
    },
    "renameObject": {
      "key": "F2",
      "description": "Rename the selected object"
    },
    "isolateSelection": {
      "key": "/",
      "description": "Toggle Isolate for the selected object(s) — dims everything outside their top-level branch"
    },
    "hideSelected": {
      "key": "H",
      "description": "Toggle visibility of selected object(s) (hiding a group cascades to all its children)"
    },
    "unhideAll": {
      "key": "H",
      "altKey": true,
      "description": "Show every hidden object at every level"
    },
    "toggleFullscreen": {
      "key": "",
      "description": "Toggle fullscreen mode (optional — browsers already bind F11 to this)"
    },
    "toggleGameMode": {
      "key": "",
      "description": "Toggle Immersive Mode"
    },
    "toggleSnapToGrid": {
      "key": "",
      "description": "Toggle snap to grid"
    },
    "toggleObjectBoundaries": {
      "key": "",
      "description": "Toggle object boundaries display"
    },
    "toggleObjectCollisions": {
      "key": "",
      "description": "Toggle object collisions display"
    },
    "openProjectSettings": {
      "key": "",
      "description": "Open project settings"
    },
    "openSettings": {
      "key": "",
      "description": "Open editor settings"
    }
  },
  "mouse": {
    "rotateObjects": {
      "key": "Drag",
      "ctrlKey": true,
      "description": "Rotate selected objects (hold Shift for 10° steps)"
    },
    "scaleObjects": {
      "key": "Drag",
      "ctrlKey": true,
      "altKey": true,
      "description": "Scale selected objects (hold Shift for 10% steps)"
    },
    "soloLayer": {
      "key": "Click",
      "ctrlKey": true,
      "description": "Solo this layer — Ctrl+click its eye icon in the Layers panel (Ctrl+click again to un-solo)"
    },
    "soloObject": {
      "key": "Click",
      "ctrlKey": true,
      "description": "Solo this object — Ctrl+click its eye icon in the Outliner; hides every other top-level object (a soloed group's own children stay visible). Ctrl+click again to un-solo"
    },
    "multiSelectFilterType": {
      "key": "Click",
      "ctrlKey": true,
      "description": "Toggle multiple type checkboxes in the Outliner filter menu without applying/closing; the accumulated filter is applied when Ctrl is released"
    }
  },
  "ui": {
    "focusLayersSearch": {
      "key": "L",
      "ctrlKey": true,
      "altKey": true,
      "description": "Focus layers search"
    },
    "addNewLayer": {
      "key": "L",
      "ctrlKey": true,
      "shiftKey": true,
      "description": "Add new layer"
    },
    "toggleLeftPanel": {
      "key": "1",
      "altKey": true,
      "description": "Toggle left panel"
    },
    "toggleRightPanel": {
      "key": "2",
      "altKey": true,
      "description": "Toggle right panel"
    },
    "toggleToolbar": {
      "key": "3",
      "altKey": true,
      "description": "Toggle toolbar"
    },
    "toggleAssetsPanel": {
      "key": "4",
      "altKey": true,
      "description": "Toggle assets panel"
    },
    "resetToDefault": {
      "key": "Backspace",
      "description": "Reset the parameter or section under the mouse cursor to its default value (Details panel and Settings panel)"
    },
    "toggleConsole": {
      "key": "",
      "description": "Toggle console panel"
    },
    "toggleStatusBar": {
      "key": "",
      "description": "Toggle status bar"
    }
  }
}
